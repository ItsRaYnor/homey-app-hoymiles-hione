  },
  "flow": {
    "triggers": [
      {
        "id": "battery_mode_changed",
        "title": {
          "en": "Battery mode changed",
          "nl": "Batterijmodus is veranderd"
        },
        "tokens": [
          {
            "name": "mode",
            "type": "string",
            "title": {
              "en": "Mode",
              "nl": "Modus"
            },
            "example": {
              "en": "Self-Consumption"
            }
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "set_battery_mode",
        "title": {
          "en": "Set battery mode",
          "nl": "Stel batterijmodus in"
        },
        "titleFormatted": {
          "en": "Set battery mode to [[mode]]",
          "nl": "Stel batterijmodus in op [[mode]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "nl": "Modus"
            },
            "values": [
              {
                "id": "1",
                "label": {
                  "en": "Self-Consumption",
                  "nl": "Eigen verbruik"
                }
              },
              {
                "id": "2",
                "label": {
                  "en": "Economy",
                  "nl": "Economie"
                }
              },
              {
                "id": "3",
                "label": {
                  "en": "Backup",
                  "nl": "Noodstroom"
                }
              },
              {
                "id": "4",
                "label": {
                  "en": "Off-Grid",
                  "nl": "Off-Grid"
                }
              },
              {
                "id": "5",
                "label": {
                  "en": "Self-Consumption + Max Power",
                  "nl": "Eigen verbruik + Max vermogen"
                }
              },
              {
                "id": "6",
                "label": {
                  "en": "Backup + Max Power",
                  "nl": "Noodstroom + Max vermogen"
                }
              },
              {
                "id": "7",
                "label": {
                  "en": "Peak Shaving",
                  "nl": "Pieksturing"
                }
              },
              {
                "id": "8",
                "label": {
                  "en": "Time of Use",
                  "nl": "Tijdafhankelijk"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_reserve_soc",
        "title": {
          "en": "Set reserve SOC",
          "nl": "Stel reserve laadniveau in"
        },
        "titleFormatted": {
          "en": "Set reserve SOC to [[soc]]%",
          "nl": "Stel reserve laadniveau in op [[soc]]%"
        },
        "hint": {
          "en": "Sets the minimum battery state of charge for the active battery mode (cloud connection required).",
          "nl": "Stelt het minimale laadniveau van de batterij in voor de actieve batterijmodus (cloudverbinding vereist)."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "soc",
            "type": "number",
            "min": 0,
            "max": 100,
            "step": 1,
            "title": {
              "en": "Reserve SOC (%)",
              "nl": "Reserve laadniveau (%)"
            }
          }
        ]
      },
      {
        "id": "set_peak_shaving",
        "title": {
          "en": "Set Peak Shaving parameters",
          "nl": "Stel Pieksturing-parameters in"
        },
        "titleFormatted": {
          "en": "Set Peak Shaving: reserve [[reserve_soc]]%, max [[max_soc]]%, grid limit [[meter_power]]W",
          "nl": "Stel Pieksturing in: reserve [[reserve_soc]]%, max [[max_soc]]%, netgrens [[meter_power]]W"
        },
        "hint": {
          "en": "Configures and activates Peak Shaving mode (cloud connection required).",
          "nl": "Configureert en activeert de Pieksturing-modus (cloudverbinding vereist)."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "reserve_soc",
            "type": "number",
            "min": 0,
            "max": 100,
            "step": 1,
            "title": {
              "en": "Reserve SOC (%)",
              "nl": "Reserve laadniveau (%)"
            }
          },
          {
            "name": "max_soc",
            "type": "number",
            "min": 0,
            "max": 100,
            "step": 1,
            "title": {
              "en": "Max SOC (%)",
              "nl": "Max laadniveau (%)"
            }
          },
          {
            "name": "meter_power",
            "type": "number",
            "min": 0,
            "max": 50000,
            "step": 100,
            "title": {
              "en": "Grid power limit (W)",
              "nl": "Netvermogensgrens (W)"
            }
          }
        ]
      },
      {
        "id": "set_relay",
        "title": {
          "en": "Switch dry contact",
          "nl": "Schakel droogcontact"
        },
        "titleFormatted": {
          "en": "Switch dry contact [[state]]",
          "nl": "Schakel droogcontact [[state]]"
        },
        "hint": {
          "en": "Enables or disables the relay / dry contact output (cloud connection and compatible hardware required).",
          "nl": "Schakelt de relais-/droogcontactuitgang in of uit (cloudverbinding en geschikte hardware vereist)."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "state",
            "type": "dropdown",
            "title": {
              "en": "State",
              "nl": "Stand"
            },
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On",
                  "nl": "Aan"
                }
              },
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "nl": "Uit"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_power_limit",
        "title": {
          "en": "Set power limit (local)",
          "nl": "Stel vermogenslimiet in (lokaal)"
        },
        "titleFormatted": {
          "en": "Limit inverter output to [[limit]]%",
          "nl": "Beperk omvormervermogen tot [[limit]]%"
        },
        "hint": {
          "en": "Limits the inverter output via the local gateway connection (LAN, port 10081). Warning: every change writes to the inverter's EEPROM — avoid changing it more than a few times per day to prevent wear.",
          "nl": "Beperkt het omvormervermogen via de lokale gateway-verbinding (LAN, poort 10081). Waarschuwing: elke wijziging schrijft naar het EEPROM-geheugen van de omvormer — wijzig dit hooguit een paar keer per dag om slijtage te voorkomen."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "limit",
            "type": "number",
            "min": 2,
            "max": 100,
            "step": 1,
            "title": {
              "en": "Power limit (%)",
              "nl": "Vermogenslimiet (%)"
            }
          }
        ]
      },
      {
        "id": "set_inverter_state",
        "title": {
          "en": "Turn inverter on/off (local)",
          "nl": "Zet omvormer aan/uit (lokaal)"
        },
        "titleFormatted": {
          "en": "Turn inverter [[serial]] [[state]]",
          "nl": "Zet omvormer [[serial]] [[state]]"
        },
        "hint": {
          "en": "Turns an inverter on or off via the local gateway connection. Enter the inverter serial number (from the type plate or the S-Miles app). Useful at negative energy prices.",
          "nl": "Zet een omvormer aan of uit via de lokale gateway-verbinding. Vul het serienummer van de omvormer in (zie typeplaatje of de S-Miles app). Handig bij negatieve stroomprijzen."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "serial",
            "type": "text",
            "title": {
              "en": "Inverter serial number",
              "nl": "Serienummer omvormer"
            },
            "placeholder": {
              "en": "e.g. 1164aabbccdd",
              "nl": "bijv. 1164aabbccdd"
            }
          },
          {
            "name": "state",
            "type": "dropdown",
            "title": {
              "en": "State",
              "nl": "Stand"
            },
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On",
                  "nl": "Aan"
                }
              },
              {
                "id": "off",
                "label": {
                  "en": "Off",
                  "nl": "Uit"
                }
              }
            ]
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "battery_mode_is",
        "title": {
          "en": "Battery mode !{{is|is not}}",
          "nl": "Batterijmodus !{{is|is niet}}"
        },
        "titleFormatted": {
          "en": "Battery mode !{{is|is not}} [[mode]]",
          "nl": "Batterijmodus !{{is|is niet}} [[mode]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hione"
          },
          {
            "name": "mode",
