      },
      "units": "kg",
      "insights": true,
      "decimals": 1,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/pv.svg"
    },
    "hoymiles_total_energy": {
      "type": "number",
      "title": {
        "en": "Total Energy",
        "nl": "Totale energie"
      },
      "units": "kWh",
      "insights": true,
      "decimals": 2,
