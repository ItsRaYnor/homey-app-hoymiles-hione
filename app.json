{
  "id": "com.hoymiles.hione",
  "version": "1.0.3",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "brandColor": "#00A94F",
  "name": {
    "en": "Hoymiles HiOne",
    "nl": "Hoymiles HiOne"
  },
  "description": {
    "en": "Monitor and control your Hoymiles HiOne battery system via S-Miles Cloud",
    "nl": "Monitor en beheer je Hoymiles HiOne batterijsysteem via S-Miles Cloud"
  },
  "tags": {
    "en": [
      "hoymiles",
      "hione",
      "solar",
      "battery",
      "bess",
      "energy",
      "smiles"
    ],
    "nl": [
      "hoymiles",
      "hione",
      "zonnepanelen",
      "batterij",
      "energie"
    ]
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "api": {
    "testLogin": {
      "method": "POST",
      "path": "/login"
    },
    "forgetLogin": {
      "method": "POST",
      "path": "/logout"
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "ItsRaYnor",
    "email": "itsraynor@users.noreply.github.com"
  },
  "source": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione",
  "support": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione/issues",
  "bugs": {
    "url": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione/issues"
  },
  "homepage": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione",
  "drivers": [
    {
      "id": "hione",
      "name": {
        "en": "HiOne Station",
        "nl": "HiOne Station"
      },
      "class": "solarpanel",
      "capabilities": [
        "measure_power",
        "meter_power",
        "measure_battery",
        "hoymiles_battery_power",
        "hoymiles_grid_power",
        "hoymiles_load_power",
        "hoymiles_pv_power",
        "hoymiles_battery_mode",
        "hoymiles_reserve_soc",
        "hoymiles_daily_energy",
        "hoymiles_monthly_energy",
        "hoymiles_yearly_energy",
        "hoymiles_total_energy",
        "hoymiles_battery_in_energy",
        "hoymiles_battery_out_energy",
        "hoymiles_co2_reduction",
        "hoymiles_profit_today",
        "hoymiles_profit_total"
      ],
      "capabilitiesOptions": {
        "measure_power": {
          "title": {
            "en": "PV Power",
            "nl": "PV Vermogen"
          }
        },
        "measure_battery": {
          "title": {
            "en": "Battery State of Charge (%)",
            "nl": "Batterij laadniveau (%)"
          }
        },
        "meter_power": {
          "title": {
            "en": "Total Energy Generated",
            "nl": "Totale energie opgewekt"
          }
        }
      },
      "energy": {
        "batteries": [
          "INTERNAL"
        ],
        "cumulative": true
      },
      "images": {
        "small": "/drivers/hione/assets/icon.png",
        "large": "/drivers/hione/assets/icon_large.png"
      },
      "pair": [
        {
          "id": "choose_connection"
        },
        {
          "id": "gateway_ip"
        },
        {
          "id": "login_credentials"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "gateway_ip",
          "type": "text",
          "label": {
            "en": "Gateway/DTS IP Address (optional)",
            "nl": "Gateway/DTS IP-adres (optioneel)"
          },
          "hint": {
            "en": "Local LAN IP of the DTS-WL-G3 stick or HiBox gateway for offline access (e.g. 192.168.1.100). Leave empty to use cloud only.",
            "nl": "Lokaal LAN IP-adres van de DTS-WL-G3 stick of HiBox gateway voor offline toegang (bijv. 192.168.1.100). Leeg laten voor cloud only."
          },
          "value": ""
        },
        {
          "id": "cloud_api_url",
          "type": "text",
          "label": {
            "en": "Cloud API URL",
            "nl": "Cloud API URL"
          },
          "hint": {
            "en": "Base URL of the S-Miles Cloud API (default: https://neapi.hoymiles.com). Only change this if Hoymiles migrates to a different endpoint.",
            "nl": "Basis-URL van de S-Miles Cloud API (standaard: https://neapi.hoymiles.com). Wijzig dit alleen als Hoymiles naar een ander endpoint migreert."
          },
          "value": "https://neapi.hoymiles.com"
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll interval (seconds)",
            "nl": "Poll-interval (seconden)"
          },
          "hint": {
            "en": "How often to fetch data (30–300 seconds). Default: 60.",
            "nl": "Hoe vaak data ophalen (30–300 seconden). Standaard: 60."
          },
          "value": 60,
          "min": 30,
          "max": 300
        },
        {
          "type": "group",
          "label": {
            "en": "Gateway info",
            "nl": "Gateway info"
          },
          "children": [
            {
              "id": "dtu_serial",
              "type": "label",
              "label": {
                "en": "Serial number",
                "nl": "Serienummer"
              },
              "value": "-"
            },
            {
              "id": "firmware_version",
              "type": "label",
              "label": {
                "en": "Firmware version",
                "nl": "Firmwareversie"
              },
              "value": "-"
            },
            {
              "id": "hardware_version",
              "type": "label",
              "label": {
                "en": "Hardware version",
                "nl": "Hardwareversie"
              },
              "value": "-"
            }
          ]
        }
      ]
    }
  ],
  "capabilities": {
    "hoymiles_battery_power": {
      "type": "number",
      "title": {
        "en": "Battery Power",
        "nl": "Batterijvermogen"
      },
      "units": "W",
      "insights": true,
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/battery.svg"
    },
    "hoymiles_grid_power": {
      "type": "number",
      "title": {
        "en": "Grid Power",
        "nl": "Netvermogen"
      },
      "units": "W",
      "insights": true,
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/grid.svg"
    },
    "hoymiles_load_power": {
      "type": "number",
      "title": {
        "en": "Load Power",
        "nl": "Belastingsvermogen"
      },
      "units": "W",
      "insights": true,
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/load.svg"
    },
    "hoymiles_pv_power": {
      "type": "number",
      "title": {
        "en": "PV Power",
        "nl": "Zonnepaneelvermogen"
      },
      "units": "W",
      "insights": true,
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/pv.svg"
    },
    "hoymiles_battery_mode": {
      "type": "enum",
      "title": {
        "en": "Battery Mode",
        "nl": "Batterijmodus"
      },
      "values": [
        {
          "id": "1",
          "title": {
            "en": "Self-Consumption",
            "nl": "Eigen verbruik"
          }
        },
        {
          "id": "2",
          "title": {
            "en": "Economy",
            "nl": "Economie"
          }
        },
        {
          "id": "3",
          "title": {
            "en": "Backup",
            "nl": "Noodstroom"
          }
        },
        {
          "id": "4",
          "title": {
            "en": "Off-Grid",
            "nl": "Off-Grid"
          }
        },
        {
          "id": "5",
          "title": {
            "en": "Self-Consumption + Max Power",
            "nl": "Eigen verbruik + Max vermogen"
          }
        },
        {
          "id": "6",
          "title": {
            "en": "Backup + Max Power",
            "nl": "Noodstroom + Max vermogen"
          }
        },
        {
          "id": "7",
          "title": {
            "en": "Peak Shaving",
            "nl": "Pieksturing"
          }
        },
        {
          "id": "8",
          "title": {
            "en": "Time of Use",
            "nl": "Tijdafhankelijk"
          }
        }
      ],
      "insights": false,
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "icon": "/assets/battery.svg"
    },
    "hoymiles_reserve_soc": {
      "type": "number",
      "title": {
        "en": "Reserve SOC",
        "nl": "Reserve laadniveau"
      },
      "units": "%",
      "min": 0,
      "max": 100,
      "step": 1,
      "decimals": 0,
      "insights": true,
      "getable": true,
      "setable": true,
      "uiComponent": "slider",
      "icon": "/assets/battery.svg"
    },
    "hoymiles_daily_energy": {
      "type": "number",
      "title": {
        "en": "Daily Energy",
        "nl": "Dagelijkse energie"
      },
      "units": "kWh",
      "insights": true,
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/pv.svg"
    },
    "hoymiles_monthly_energy": {
      "type": "number",
      "title": {
        "en": "Monthly Energy",
