{
  "id": "com.hoymiles.hione",
  "version": "1.0.5",
  "compatibility": ">=12.4.5",
  "sdk": 3,
  "brandColor": "#00A94F",
  "name": {
    "en": "Hoymiles HiOne",
    "nl": "Hoymiles HiOne"
  },
  "description": {
    "en": "Monitor and control your Hoymiles HiOne battery system via S-Miles Cloud",
    "nl": "Monitor en beheer je Hoymiles HiOne batterijsysteem via S-Miles Cloud"
  },
  "tags": {
    "en": [
      "hoymiles",
      "hione",
      "solar",
      "battery",
      "bess",
      "energy",
      "smiles"
    ],
    "nl": [
      "hoymiles",
      "hione",
      "zonnepanelen",
      "batterij",
      "energie"
    ]
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "api": {
    "testLogin": {
      "method": "POST",
      "path": "/login"
    },
    "forgetLogin": {
      "method": "POST",
      "path": "/logout"
    },
    "scanModbus": {
      "method": "POST",
      "path": "/modbus/scan"
    },
    "getDiagnostics": {
      "method": "POST",
      "path": "/diagnostics"
    }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "ItsRaYnor",
    "email": "itsraynor@users.noreply.github.com"
  },
  "source": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione",
  "support": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione/issues",
  "bugs": {
    "url": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione/issues"
  },
  "homepage": "https://github.com/ItsRaYnor/homey-app-hoymiles-hione",
  "drivers": [
    {
      "id": "hione",
      "name": {
        "en": "HiOne Station",
        "nl": "HiOne Station"
      },
      "class": "battery",
      "capabilities": [
        "measure_power",
        "hoymiles_battery_flow",
        "measure_battery",
        "meter_power.charged",
        "meter_power.discharged",
        "hoymiles_grid_power",
        "hoymiles_load_power",
        "hoymiles_pv_power",
        "hoymiles_battery_mode",
        "hoymiles_reserve_soc",
        "hoymiles_max_soc",
        "hoymiles_max_charge_power",
        "hoymiles_max_discharge_power",
        "hoymiles_meter_power",
        "hoymiles_daily_energy",
        "hoymiles_monthly_energy",
        "hoymiles_yearly_energy",
        "hoymiles_total_energy",
        "hoymiles_co2_reduction",
        "hoymiles_profit_today",
        "hoymiles_profit_total"
      ],
      "capabilitiesOptions": {
        "measure_power": {
          "title": {
            "en": "Battery Power (+ charge / − discharge)",
            "nl": "Accuvermogen (+ laden / − ontladen)"
          }
        },
        "measure_battery": {
          "title": {
            "en": "Battery State of Charge (%)",
            "nl": "Batterij laadniveau (%)"
          }
        },
        "meter_power.charged": {
          "title": {
            "en": "Battery Charged",
            "nl": "Accu geladen"
          },
          "insights": true,
          "decimals": 2
        },
        "meter_power.discharged": {
          "title": {
            "en": "Battery Discharged",
            "nl": "Accu ontladen"
          },
          "insights": true,
          "decimals": 2
        }
      },
      "energy": {
        "homeBattery": true,
        "meterPowerImportedCapability": "meter_power.charged",
        "meterPowerExportedCapability": "meter_power.discharged"
      },
      "images": {
        "small": "/drivers/hione/assets/icon.png",
        "large": "/drivers/hione/assets/icon_large.png"
      },
      "pair": [
        {
          "id": "choose_connection"
        },
        {
          "id": "gateway_ip"
        },
        {
          "id": "login_credentials"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "gateway_ip",
          "type": "text",
          "label": {
            "en": "Gateway/DTS IP Address (optional)",
            "nl": "Gateway/DTS IP-adres (optioneel)"
          },
          "hint": {
            "en": "Local LAN IP of the DTS-WL-G3 stick or HiBox gateway for offline access (e.g. 192.168.1.100). Leave empty to use cloud only.",
            "nl": "Lokaal LAN IP-adres van de DTS-WL-G3 stick of HiBox gateway voor offline toegang (bijv. 192.168.1.100). Leeg laten voor cloud only."
          },
          "value": ""
        },
        {
          "id": "cloud_api_url",
          "type": "text",
          "label": {
            "en": "Cloud API URL",
            "nl": "Cloud API URL"
          },
          "hint": {
            "en": "Base URL of the S-Miles Cloud API (default: https://neapi.hoymiles.com). Only change this if Hoymiles migrates to a different endpoint.",
            "nl": "Basis-URL van de S-Miles Cloud API (standaard: https://neapi.hoymiles.com). Wijzig dit alleen als Hoymiles naar een ander endpoint migreert."
          },
          "value": "https://neapi.hoymiles.com"
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll interval (seconds)",
            "nl": "Poll-interval (seconden)"
          },
          "hint": {
            "en": "How often to fetch data (30–300 seconds). Default: 60.",
            "nl": "Hoe vaak data ophalen (30–300 seconden). Standaard: 60."
          },
          "value": 60,
          "min": 30,
          "max": 300
        },
        {
          "type": "group",
          "label": {
            "en": "System info",
            "nl": "Systeeminfo"
          },
          "children": [
            {
              "id": "gateway_model",
              "type": "label",
              "label": {
                "en": "Model",
                "nl": "Model"
              },
              "value": "-"
            },
            {
              "id": "dtu_serial",
              "type": "label",
              "label": {
                "en": "Serial number",
                "nl": "Serienummer"
              },
              "value": "-"
            },
            {
              "id": "firmware_version",
              "type": "label",
              "label": {
                "en": "Firmware version",
                "nl": "Firmwareversie"
              },
              "value": "-"
            },
            {
              "id": "hardware_version",
              "type": "label",
              "label": {
                "en": "Hardware version",
                "nl": "Hardwareversie"
              },
              "value": "-"
            },
            {
              "id": "system_devices",
              "type": "textarea",
              "label": {
                "en": "Connected devices",
                "nl": "Gekoppelde apparaten"
              },
              "value": "-"
            }
          ]
        }
      ]
    }
  ],
